И","target":"ФУНКЦИЯ АКТИВАЦИИ","line":55,"embedded":true},{"title":"Тензор","target":"Тензор","line":57,"embedded":true}],"task_lines":[],"tasks":{},"codeblock_ranges":[[10,12],[44,48],[64,66],[84,86],[109,111],[133,135],[140,142],[156,159]],"last_embed":{"hash":"1fxeut3","at":1772977964697},"key":"Программирование/AI/Нейронки/Базовые понятия.md"},
